# AI 小说转剧本工具 — Environment Variables
# 复制此文件为 .env.local 并填入真实值

# ---- DeepSeek（推荐，国内可直接访问）----
DEEPSEEK_API_KEY=请在这里粘贴你的DeepSeek API Key
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com

